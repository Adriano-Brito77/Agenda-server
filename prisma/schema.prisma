// Try Prisma Accelerate: https://pris.ly/cli/accelerate-init

generator client {
  provider = "prisma-client"
  output   = "../generated/prisma"
  moduleFormat = "cjs"
}

datasource db {
  provider = "postgresql"
}



enum UserRole {
  user
  admin
  professional
}

enum StockMovementType {
  IN
  OUT
}

enum ReferenceType {
  PURCHASE   //IN
  ENTRY      //IN
  SALE       //OUT
  STOCK_OUT  //OUT
}

enum Status {
  PENDING
  APPROVED
  REJECTED
  CANCELED
}

model User {
  id String @id @default(uuid())

  name                  String
  email                 String
  cpf                   String
  role UserRole
  birth_day             DateTime?
  password_hash         String
  notification_time     Int?
  phone_number         String?
  occupation           String?
  company_id           String? 

  professional_services ProfessionalService[]
  professional_schedules ProfessionalSchedule[]
  work_days WorkDays[]

  

  created_at DateTime @default(now())
  updated_at DateTime @updatedAt  

  @@map("users")
}


model Company {
  id String @id @default(uuid())

  name        String
  email       String
  cnpj        String  
  phone_number String
  open_date DateTime
  start_time String
  end_time   String
  address    String

  user_id     String 

  company_services CompanyService[]
  professional_services ProfessionalService[]
  professional_schedules ProfessionalSchedule[]
  exception_days ExceptionDays[]
  products Products[]
  purchase_orders PurchaseOrder[]
  
  
  

  created_at DateTime @default(now())
  updated_at DateTime @updatedAt  

  @@map("companies")
}


model CompanyService {
  id String @id @default(uuid())

  name        String
  description String

  company_id  String 
  company    Company @relation(fields: [company_id], references: [id]) 

  professional_services ProfessionalService[]
  

  created_at DateTime @default(now())
  updated_at DateTime @updatedAt  

  @@map("company_services")
}

model ProfessionalService {
  id String @id @default(uuid())

  value       Float
  description String
  duration    Int

  company_id          String 
  company             Company @relation(fields: [company_id], references: [id]) 

  company_service_id   String 
  company_service      CompanyService @relation(fields: [company_service_id], references: [id]) 

  professional_id      String 
  professional         User @relation(fields: [professional_id], references: [id]) 

  created_at DateTime @default(now())
  updated_at DateTime @updatedAt  

  @@map("professional_services")
}

model ProfessionalSchedule {
  id String @id @default(uuid())

  hire_date        DateTime
  start_time  String
  end_time    String
  break_start_time String
  break_end_time String

  professional_id      String 
  professional         User @relation(fields: [professional_id], references: [id]) 

  company_id          String 
  company             Company @relation(fields: [company_id], references: [id])

  created_at DateTime @default(now())
  updated_at DateTime @updatedAt  

  @@map("professional_schedules")
}

model WorkDays {
  id String @id @default(uuid())

  day_of_week Int

  professional_id String
  professional User @relation(fields: [professional_id], references: [id])

  created_at DateTime @default(now())
  updated_at DateTime @updatedAt  

  @@map("work_days")
}

model ExceptionDays {
  id String @id @default(uuid())

  date DateTime
  start_time String?
  end_time String?
  professional_id String?
  

  company_id String
  company Company @relation(fields: [company_id], references: [id])

  created_at DateTime @default(now())
  updated_at DateTime @updatedAt  

  @@map("exception_days")
}


model Products {
  id String @id @default(uuid())

  name        String
  description String
  barcode     String  
  price       Float
  unit        String

  company_id  String 
  company    Company @relation(fields: [company_id], references: [id])

  created_at DateTime @default(now())
  updated_at DateTime @updatedAt  

  stock_movements StockMovements[]
  stock_balances StockBalance[]
  order_items OrderItem[]


  @@map("products")
}

model StockMovements {
  id String @id @default(uuid())

  type              StockMovementType
  reference_type    ReferenceType
  quantity Int
  unit_price Float
  total_value Float
  movement_date DateTime

  purchase_order_id String?

  product_id String
  product Products @relation(fields: [product_id], references: [id])

  created_at DateTime @default(now())
  updated_at DateTime @updatedAt  

  @@map("stock_movements")
 
}

model StockBalance{
  id String @id @default(uuid())

  quantity Int  

  product_id String  @unique
  product Products @relation(fields: [product_id], references: [id])

  

  created_at DateTime @default(now())
  updated_at DateTime @updatedAt  

  @@map("stock_balances")

}

model PurchaseOrder {
  id String @id @default(uuid())

  company_id String
  company Company @relation(fields: [company_id], references: [id])

  order_amount Float
  order_date DateTime
  requester_name String

  status Status

  payment_method String
  pickup_date DateTime?

  created_at DateTime @default(now())
  updated_at DateTime @updatedAt  

  order_items OrderItem[]

  @@map("purchase_orders")

}

model OrderItem {
  id String @id @default(uuid())

  purchase_order_id String
  purchase_order PurchaseOrder @relation(fields: [purchase_order_id], references: [id])

  product_id String
  product Products @relation(fields: [product_id], references: [id])

  name String
  quantity Int
  unit_price Float
  total_value Float

  created_at DateTime @default(now())
  updated_at DateTime @updatedAt  

  @@map("order_items")
}
