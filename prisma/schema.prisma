// Try Prisma Accelerate: https://pris.ly/cli/accelerate-init

generator client {
  provider = "prisma-client"
  output   = "../generated/prisma"
  moduleFormat = "cjs"
}

datasource db {
  provider = "postgresql"
}



enum UserRole {
  user
  admin
  professional
}

model User {
  id String @id @default(uuid())

  name                  String
  email                 String
  cpf                   String
  role UserRole
  birth_day             DateTime?
  password_hash         String
  notification_time     Int?
  phone_number         String?
  occupation           String?
  company_id           String? 

  professional_services ProfessionalService[]
  professional_schedules ProfessionalSchedule[]
  work_days WorkDays[]

  

  created_at DateTime @default(now())
  updated_at DateTime @updatedAt  

  @@map("users")
}


model Company {
  id String @id @default(uuid())

  name        String
  email       String
  cnpj        String  
  phone_number String
  open_date DateTime
  start_time String
  end_time   String
  address    String

  user_id     String 

  company_services CompanyService[]
  professional_services ProfessionalService[]
  professional_schedules ProfessionalSchedule[]
  exception_days ExceptionDays[]
  
  

  created_at DateTime @default(now())
  updated_at DateTime @updatedAt  

  @@map("companies")
}


model CompanyService {
  id String @id @default(uuid())

  name        String
  description String

  company_id  String 
  company    Company @relation(fields: [company_id], references: [id]) 

  prodessional_services ProfessionalService[]

  created_at DateTime @default(now())
  updated_at DateTime @updatedAt  

  @@map("company_services")
}

model ProfessionalService {
  id String @id @default(uuid())

  value       Float
  description String
  duration    Int

  company_id          String 
  company             Company @relation(fields: [company_id], references: [id]) 

  company_service_id   String 
  company_service      CompanyService @relation(fields: [company_service_id], references: [id]) 

  professional_id      String 
  professional         User @relation(fields: [professional_id], references: [id]) 

  created_at DateTime @default(now())
  updated_at DateTime @updatedAt  

  @@map("professional_services")
}

model ProfessionalSchedule {
  id String @id @default(uuid())

  hire_date        DateTime
  start_time  String
  end_time    String
  break_start_time String
  break_end_time String

  professional_id      String 
  professional         User @relation(fields: [professional_id], references: [id]) 

  company_id          String 
  company             Company @relation(fields: [company_id], references: [id])

  created_at DateTime @default(now())
  updated_at DateTime @updatedAt  

  @@map("professional_schedules")
}

model WorkDays {
  id String @id @default(uuid())

  day_of_week Int

  professional_id String
  professional User @relation(fields: [professional_id], references: [id])

  created_at DateTime @default(now())
  updated_at DateTime @updatedAt  

  @@map("work_days")
}

model ExceptionDays {
  id String @id @default(uuid())

  date DateTime
  start_time String?
  end_time String?
  professional_id String?
  

  company_id String
  company Company @relation(fields: [company_id], references: [id])

  created_at DateTime @default(now())
  updated_at DateTime @updatedAt  

  @@map("exception_days")
}