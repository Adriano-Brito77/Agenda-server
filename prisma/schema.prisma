// learn more about it in the docs: https://pris.ly/d/prisma-schema

// Looking for ways to speed up your queries, or scale easily with your serverless or edge functions?
// Try Prisma Accelerate: https://pris.ly/cli/accelerate-init

generator client {
  provider = "prisma-client"
  output   = "../generated/prisma"
  moduleFormat = "cjs"
}

datasource db {
  provider = "postgresql"
}

enum StockMovementType {
  IN
  OUT
}

enum ReferenceType {
  PURCHASE   //IN
  ENTRY      //IN
  SALE       //OUT
  STOCK_OUT  //OUT
}

enum Status {
  PENDING
  APPROVED
  REJECTED
  CANCELED
}

enum StatusSchedule {
  APPROVED
  COMPLETED
  CANCELED  
  PENDING
} 

model User {
  id String @id @default(uuid())

  name                  String
  email                 String @unique
  cpf                   String @unique
  birth_day             DateTime?
  password_hash         String
  notification_time     Int?
  phone_number         String?
  occupation           String?
  company_id           String? 

  professional_services ProfessionalService[]
  professional_schedules ProfessionalSchedule[]
  work_days WorkDays[]
  
  company Company[]
  exception_days ExceptionDays[]

  companies CompanyUser[]
  company_user CompanyUser[] @relation("CompanyUserCreator")

  schedules_created         Schedules[] @relation("ScheduleCreator")
  schedules_as_professional Schedules[] @relation("ScheduleProfessional")


  created_at DateTime @default(now())
  updated_at DateTime @updatedAt  

  @@map("users")
}


model Company {
  id String @id @default(uuid())

  name        String
  email       String @unique
  cnpj        String  @unique
  phone_number String
  open_date DateTime
  start_time String
  end_time   String
  address    String
  cep       String
  number    String
  complement String?

  creator_id     String 
  creator        User @relation(fields: [creator_id], references: [id])

  company_services CompanyService[]
  professional_services ProfessionalService[]
  professional_schedules ProfessionalSchedule[]
  exception_days ExceptionDays[]
  products Products[]
  purchase_orders PurchaseOrder[]
  schedules Schedules[]
  company_users CompanyUser[]
  
  
  

  created_at DateTime @default(now())
  updated_at DateTime @updatedAt  

  @@map("companies")
}

model CompanyUser{
  id String @id @default(uuid())

  company_id String
  company Company @relation(fields: [company_id], references: [id])

  professional_id String
  professional User @relation(fields: [professional_id], references: [id])

  creator_id String
  creator User @relation("CompanyUserCreator", fields: [creator_id], references: [id])

  is_active Boolean @default(true)
  

  created_at DateTime @default(now())
  updated_at DateTime @updatedAt  

  @@map("company_users")


}


model CompanyService {
  id String @id @default(uuid())

  name        String
  description String

  company_id  String 
  company    Company @relation(fields: [company_id], references: [id]) 

  professional_services ProfessionalService[]
  

  created_at DateTime @default(now())
  updated_at DateTime @updatedAt  

  @@map("company_services")
}

model ProfessionalService {
  id String @id @default(uuid())

  
  value       Float
  description String
  duration    Int

  company_id          String 
  company             Company @relation(fields: [company_id], references: [id]) 

  company_service_id   String 
  company_service      CompanyService @relation(fields: [company_service_id], references: [id]) 

  professional_id      String 
  professional         User @relation(fields: [professional_id], references: [id]) 


  created_at DateTime @default(now())
  updated_at DateTime @updatedAt  

  schedules Schedules[]

  @@map("professional_services")
}

model ProfessionalSchedule {
  id String @id @default(uuid())

  hire_date        DateTime
  start_time  String
  end_time    String
  break_start_time String
  break_end_time String

  professional_id      String 
  professional         User @relation(fields: [professional_id], references: [id]) 

  company_id          String 
  company             Company @relation(fields: [company_id], references: [id])

  created_at DateTime @default(now())
  updated_at DateTime @updatedAt  

  @@map("professional_schedules")
}

model WorkDays {
  id String @id @default(uuid())

  day_of_week Int

  professional_id String
  professional User @relation(fields: [professional_id], references: [id])

  created_at DateTime @default(now())
  updated_at DateTime @updatedAt  

  @@map("work_days")
}

model ExceptionDays {
  id String @id @default(uuid())

  date DateTime
  start_time String?
  end_time String?

  professional_id String? 
  professional User? @relation(fields: [professional_id], references: [id])

  company_id String
  company Company @relation(fields: [company_id], references: [id])

  created_at DateTime @default(now())
  updated_at DateTime @updatedAt  

  @@map("exception_days")
}


model Products {
  id String @id @default(uuid())

  name        String
  description String
  barcode     String  
  price       Float
  unit        String

  company_id  String 
  company    Company @relation(fields: [company_id], references: [id])

  created_at DateTime @default(now())
  updated_at DateTime @updatedAt  

  stock_movements StockMovements[]
  stock_balances StockBalance[]
  order_items OrderItem[]


  @@map("products")
}

model StockMovements {
  id String @id @default(uuid())

  type              StockMovementType
  reference_type    ReferenceType
  quantity Int
  unit_price Float
  total_value Float
  movement_date DateTime

  purchase_order_id String?

  product_id String
  product Products @relation(fields: [product_id], references: [id])

  created_at DateTime @default(now())
  updated_at DateTime @updatedAt  

  @@map("stock_movements")
 
}

model StockBalance{
  id String @id @default(uuid())

  quantity Int  

  product_id String  @unique
  product Products @relation(fields: [product_id], references: [id])

  

  created_at DateTime @default(now())
  updated_at DateTime @updatedAt  

  @@map("stock_balances")

}

model PurchaseOrder {
  id String @id @default(uuid())

  company_id String
  company Company @relation(fields: [company_id], references: [id])

  order_amount Float
  order_date DateTime
  requester_name String

  status Status

  payment_method String
  pickup_date DateTime?

  created_at DateTime @default(now())
  updated_at DateTime @updatedAt  

  order_items OrderItem[]

  @@map("purchase_orders")

}

model OrderItem {
  id String @id @default(uuid())

  purchase_order_id String
  purchase_order PurchaseOrder @relation(fields: [purchase_order_id], references: [id])

  product_id String
  product Products @relation(fields: [product_id], references: [id])

  name String
  quantity Int
  unit_price Float
  total_value Float

  created_at DateTime @default(now())
  updated_at DateTime @updatedAt  

  @@map("order_items")
}


model Schedules{
  id String @id @default(uuid())

  starts_at          DateTime
  ends_at            DateTime
  duration_in_minutes Int

  is_paid Boolean
  notification Boolean
  status StatusSchedule

  notes String?

  client_name_external String?
  client_email_external String?
  number String

  creator_id String
  creator User @relation("ScheduleCreator", fields: [creator_id], references: [id])

  client_id String?
  

  professional_id String
  professional User @relation("ScheduleProfessional", fields: [professional_id], references: [id])

  professional_service_id String
  professional_service ProfessionalService @relation(fields: [professional_service_id], references: [id])

  company_id String 
  company Company @relation(fields: [company_id], references: [id])

  created_at DateTime @default(now())
  updated_at DateTime @updatedAt  


  @@index([professional_id, starts_at, ends_at])
  @@index([company_id, starts_at])

  @@map("schedules")
}

model ScheduleServices{
  id String @id @default(uuid()) 
  schedule_id String
  service_id String
  name String
  value Float
  duration Int

  @@map("scheduleservices")
}